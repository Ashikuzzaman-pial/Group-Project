<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="mainPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group_project.GeneralMember.Controller.SubmitApplicationController">
   <children>
      <Label layoutX="194.0" layoutY="28.0" text="Apply For Welfare application">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
      </Label>
      <Label layoutX="51.0" layoutY="77.0" text="Application Type:" />
      <ComboBox fx:id="ApplicationTypeCB" layoutX="158.0" layoutY="73.0" prefHeight="25.0" prefWidth="121.0" />
      <Label layoutX="51.0" layoutY="118.0" text="Description:" />
      <TextArea fx:id="DescriptionTA" layoutX="125.0" layoutY="118.0" prefHeight="150.0" prefWidth="399.0" />
      <Label layoutX="300.0" layoutY="77.0" text="Requested Amount:" />
      <TextField fx:id="RequestedAmountTF" layoutX="418.0" layoutY="73.0" />
      <Button layoutX="254.0" layoutY="299.0" mnemonicParsing="false" onAction="#SubmitButtonOA" prefHeight="35.0" prefWidth="75.0" text="Submit" />
      <Label fx:id="StatusLabel" layoutX="214.0" layoutY="349.0" prefHeight="35.0" prefWidth="158.0" />
      <Button layoutX="517.0" layoutY="355.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="33.0" prefWidth="71.0" text="Back" />
   </children>
</AnchorPane>
