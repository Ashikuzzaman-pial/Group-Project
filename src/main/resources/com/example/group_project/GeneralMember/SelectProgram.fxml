<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="mainPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group_project.GeneralMember.Controller.SelectProgramController">
   <children>
      <Label layoutX="216.0" layoutY="14.0" text="Select Welfare Program">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
      </Label>
      <Label layoutX="88.0" layoutY="73.0" text="Programs:" />
      <ComboBox fx:id="ProgramsCB" layoutX="150.0" layoutY="69.0" prefWidth="150.0" />
      <Label layoutX="88.0" layoutY="112.0" text="Description:" />
      <TextField fx:id="DescriptionTA" layoutX="164.0" layoutY="117.0" prefHeight="100.0" prefWidth="385.0" />
      <Label layoutX="105.0" layoutY="238.0" text="Amount:" />
      <TextField fx:id="AmountTF" layoutX="164.0" layoutY="234.0" />
      <Button layoutX="274.0" layoutY="290.0" mnemonicParsing="false" onAction="#SubmitButtonOA" text="Submit" />
      <Button layoutX="517.0" layoutY="355.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="33.0" prefWidth="71.0" text="Back" />
   </children>
</AnchorPane>
