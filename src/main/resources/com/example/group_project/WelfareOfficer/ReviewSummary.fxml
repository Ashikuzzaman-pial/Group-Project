<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="mainPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group_project.WelfareOfficer.Controller.ReviewSummaryController">
   <children>
      <Label fx:id="ReviewSummaryLabel" layoutX="221.0" layoutY="23.0" prefHeight="27.0" prefWidth="152.0" text="Review Summary" textFill="#d30d69">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="35.0" layoutY="72.0" text="From:" textFill="#d30d69" />
      <Label layoutX="401.0" layoutY="72.0" text="To:" textFill="#d30d69" />
      <DatePicker fx:id="fromDP" layoutX="77.0" layoutY="68.0" prefHeight="25.0" prefWidth="111.0" />
      <DatePicker fx:id="toDP" layoutX="430.0" layoutY="68.0" prefHeight="25.0" prefWidth="111.0" />
      <Button layoutX="245.0" layoutY="101.0" mnemonicParsing="false" onAction="#loadSummaryButtonOA" prefHeight="42.0" prefWidth="111.0" text="Load Summary" textFill="#d30d69" />
      <TableView fx:id="TableViewTV" layoutX="97.0" layoutY="171.0" prefHeight="179.0" prefWidth="401.0">
        <columns>
          <TableColumn fx:id="reviewIDTC" prefWidth="67.0" text="Review ID" />
          <TableColumn fx:id="applicationIDTC" prefWidth="93.0" text="Application ID" />
            <TableColumn fx:id="decisionTC" prefWidth="61.0" text="Decision" />
            <TableColumn fx:id="remarksTC" prefWidth="76.0" text="Remarks" />
            <TableColumn fx:id="dateTC" prefWidth="103.0" text="Date" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
