<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="mainPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group_project.WelfareOfficer.Controller.DeleteReviewController">
   <children>
      <Button layoutX="250.0" layoutY="270.0" mnemonicParsing="false" onAction="#DeleteButtonOA" prefHeight="44.0" prefWidth="114.0" text="Delete" textFill="#d30d69" />
      <Label fx:id="deleteReviewLabel" layoutX="256.0" layoutY="14.0" text="Delete Review" textFill="#d30d69">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="212.0" layoutY="120.0" text="Select Review:" textFill="#d30d69" />
      <ComboBox fx:id="selectReviewCB" layoutX="300.0" layoutY="116.0" prefHeight="25.0" prefWidth="121.0" />
      <Label fx:id="errorLabel" layoutX="243.0" layoutY="192.0" text="Please select a review" textFill="#d30d69" />
      <Button layoutX="525.0" layoutY="338.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="25.0" prefWidth="48.0" text="Back" textFill="#d30d69" />
   </children>
</AnchorPane>
