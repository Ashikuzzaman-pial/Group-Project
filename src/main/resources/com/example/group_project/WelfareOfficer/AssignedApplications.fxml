<AnchorPane fx:id="mainPane" prefHeight="477.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group_project.WelfareOfficer.Controller.AssignedApplicationsController">
   <children>
      <TableView fx:id="tableViewTV" layoutX="32.0" layoutY="168.0" prefHeight="200.0" prefWidth="539.0">
        <columns>
          <TableColumn fx:id="applicationIdTC" prefWidth="94.0" text="Application Id" />
          <TableColumn fx:id="employeeNameTC" prefWidth="110.0" text="Employee Name" />
            <TableColumn fx:id="programTC" prefWidth="99.0" text="Program" />
            <TableColumn fx:id="dateTC" prefWidth="126.0" text="Date" />
            <TableColumn fx:id="statusTC" prefWidth="109.0" text="Status" />
        </columns>
      </TableView>
      <Button layoutX="231.0" layoutY="385.0" mnemonicParsing="false" onAction="#ViewDetailsButtonOA" prefHeight="40.0" prefWidth="139.0" text="View Details" />
      <Label fx:id="assignedApplicationLabel" layoutX="212.0" layoutY="20.0" text="Assigned Application">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="54.0" layoutY="64.0" text="Status:" />
      <ComboBox fx:id="statusCB" layoutX="100.0" layoutY="60.0" prefHeight="25.0" prefWidth="100.0" />
      <Label fx:id="statusLabel" layoutX="227.0" layoutY="64.0" text="From:" />
      <Label layoutX="425.0" layoutY="64.0" text="To:" />
      <DatePicker fx:id="fromDP" layoutX="276.0" layoutY="60.0" prefHeight="25.0" prefWidth="100.0" />
      <DatePicker fx:id="toDP" layoutX="452.0" layoutY="60.0" prefHeight="25.0" prefWidth="100.0" />
      <Button layoutX="242.0" layoutY="105.0" mnemonicParsing="false" onAction="#filterButtonOA" prefHeight="40.0" prefWidth="121.0" text="Filter" />
      <Label layoutX="213.0" layoutY="438.0" prefHeight="25.0" prefWidth="180.0" text="No assigned applications found" />
   </children>
</AnchorPane>
