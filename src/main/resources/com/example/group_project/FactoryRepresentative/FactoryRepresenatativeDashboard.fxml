      <Button layoutX="28.0" layoutY="273.0" mnemonicParsing="false" onAction="#deleteEmployeeButtonOA" text="Delete Employee" />
      <Button layoutX="36.0" layoutY="316.0" mnemonicParsing="false" onAction="#employeeListButtonOA" text="Employee List" />
      <Button layoutX="37.0" layoutY="355.0" mnemonicParsing="false" onAction="#welfareIssueButtonOA" text="Welfare Issue" />
      <Button layoutX="548.0" layoutY="21.0" mnemonicParsing="false" onAction="#logoutButtonOA" text="Logout" />
   </children>
</AnchorPane>
