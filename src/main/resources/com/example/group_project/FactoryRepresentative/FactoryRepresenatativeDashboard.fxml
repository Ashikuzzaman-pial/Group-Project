<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="624.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group_project.FactoryRepresentative.FactoryRepresentativeDashboardController">
   <children>
      <Label fx:id="factoryRepresentativeDashboardLabel" alignment="TOP_CENTER" contentDisplay="CENTER" layoutX="165.0" layoutY="20.0" prefHeight="27.0" prefWidth="298.0" text="Factory Representative Dashboard">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label fx:id="welcomeFactoryRepresentativeLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="180.0" layoutY="183.0" prefHeight="35.0" prefWidth="269.0" text="Welcome, Factory Representative!" textFill="#130872">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Button layoutX="30.0" layoutY="56.0" mnemonicParsing="false" onAction="#registerFactoryButtonOA" text="Register Factory" />
      <Button layoutX="32.0" layoutY="98.0" mnemonicParsing="false" onAction="#updateFactoryButtonOA" text="Update Factory" />
      <Button layoutX="34.0" layoutY="141.0" mnemonicParsing="false" onAction="#deleteFactoryButtonOA" text="Delete Factory" />
